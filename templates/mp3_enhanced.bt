    char id[4] = { "SYLT" };
    uint32 size <min=6, max=4096>;
    ID3V2_FRAME_FLAGS flags;
    ubyte encoding <min=0, max=3>;
    char language[3];
    ubyte timestamp_format <min=1, max=2>;
