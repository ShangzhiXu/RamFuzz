#define MAX_MPEG_FRAMES 5
#define MAX_ID3V2_FRAMES 12

//------------------------------------------------
//--- 010 Editor Binary Template
//
//      File: mp3_enhanced.bt
//   Authors: Extended from Ivan Getta's MP3.bt
//   Version: 2.0
//   Purpose: Comprehensive MP3 template covering all elements from 04_type_values.json:
//            Frame Header, Side Info, ID3v1/v1.1, ID3v2 (v2.2/v2.3/v2.4),
//            Xing/Info header, LAME header, VBRI header, APE tags, Lyrics3v2.
//  Category: Audio
// File Mask: *.mp3
//  ID Bytes: 49 44 33, FF FB, FF FA, FF F3, FF F2
//   History:
//   2.0   2025-03-14 Full coverage of MP3 type values from JSON spec.
//------------------------------------------------

BigEndian();

// ============================================================
// Forward declarations
// ============================================================
struct mp3_id3v2_tag;
struct mp3_mpeg_frame;
struct mp3_id3v1_tag;
struct mp3_ape_tag;

// ============================================================
// Constants & Lookup Tables
// ============================================================

// Bitrate table [mpeg_version_index][layer_index][bitrate_index]
// mpeg_version_index: 0=MPEG2/2.5, 1=MPEG1
// layer_index: 0=Layer1, 1=Layer2, 2=Layer3
local const uint32 bitrate_table[2 * 3 * 16] = {
    // MPEG2/2.5 Layer1
    0, 32, 48, 56, 64, 80, 96, 112, 128, 144, 160, 176, 192, 224, 256, 0,
    // MPEG2/2.5 Layer2
    0, 8, 16, 24, 32, 40, 48, 56, 64, 80, 96, 112, 128, 144, 160, 0,
    // MPEG2/2.5 Layer3
    0, 8, 16, 24, 32, 40, 48, 56, 64, 80, 96, 112, 128, 144, 160, 0,
    // MPEG1 Layer1
    0, 32, 64, 96, 128, 160, 192, 224, 256, 288, 320, 352, 384, 416, 448, 0,
    // MPEG1 Layer2
    0, 32, 48, 56, 64, 80, 96, 112, 128, 160, 192, 224, 256, 320, 384, 0,
    // MPEG1 Layer3
    0, 32, 40, 48, 56, 64, 80, 96, 112, 128, 160, 192, 224, 256, 320, 0
};

// Sample rate table [mpeg_version][sr_index]
local const uint32 samplerate_table[4 * 4] = {
    // MPEG2.5
    11025, 12000, 8000, 0,
    // reserved
    0, 0, 0, 0,
    // MPEG2
    22050, 24000, 16000, 0,
    // MPEG1
    44100, 48000, 32000, 0
};

// Samples per frame [mpeg_version][layer]
// layer: 0=reserved, 1=Layer3, 2=Layer2, 3=Layer1
local const uint32 samples_per_frame[4 * 4] = {
    // MPEG2.5
    0, 576, 1152, 384,
    // reserved
    0, 0, 0, 0,
    // MPEG2
    0, 576, 1152, 384,
    // MPEG1
    0, 1152, 1152, 384
};

local const uint32 slot_size_table[4] = { 0, 1, 1, 4 }; // [layer_id]

// ReadBytesInitValues for the top-level structure
local string ReadBytesInitValues[] = {
    "ID3", "\xFF\xFB", "\xFF\xFA", "\xFF\xF3", "\xFF\xF2",
    "\xFF\xFF", "\xFF\xFE", "\xFF\xFD", "\xFF\xFC",
    "\xFF\xF7", "\xFF\xF6", "\xFF\xF5", "\xFF\xF4",
    "TAG"
};

// ============================================================
// Helper: synchsafe integer encode/decode
// ============================================================
typedef struct {
    ubyte b0;
    ubyte b1;
    ubyte b2;
    ubyte b3;
    local uint32 decoded = ((uint32)b0 << 21) | ((uint32)b1 << 14) |
                           ((uint32)b2 << 7)  | (uint32)b3;
} syncsafe_uint32;

string read_syncsafe(syncsafe_uint32 &v) {
    string s;
    SPrintf(s, "%u", v.decoded);
    return s;
}

void write_syncsafe_at(uint32 value, int64 pos) {
    local ubyte b3 = value & 0x7F;
    local ubyte b2 = (value >> 7) & 0x7F;
    local ubyte b1 = (value >> 14) & 0x7F;
    local ubyte b0 = (value >> 21) & 0x7F;
    local int64 save = FTell();
    FSeek(pos);
    // Write individual bytes
    ubyte ss_b0 = { b0 };
    ubyte ss_b1 = { b1 };
    ubyte ss_b2 = { b2 };
    ubyte ss_b3 = { b3 };
    FSeek(save);
}

// ============================================================
// ID3v2 Tag
// ============================================================

struct ID3V2_FRAME_FLAGS {
    ubyte flags1 = { 0 };
    ubyte flags2 = { 0 };
};

struct ID3V2_TEXT_FRAME {
    // Covers TIT2, TIT3, TPE1-4, TALB, TYER, TDRC, TRCK, TPOS, TCON, TCOM,
    // TPUB, TEXT, TENC, TSSE, TLEN, TBPM, TKEY, TLAN, TFLT, TMED, TSRC,
    // TOAL, TOFN, TOLY, TOPE, TOWN, TRSN, TRSO, TSIZ, TDRL, TDTG, TDEN,
    // TDOR, TMOO, TPRO, TSOA, TSOP, TSOT, TSST
    char id[4] = {
        "TIT2", "TIT3", "TPE1", "TPE2", "TPE3", "TPE4",
        "TALB", "TYER", "TDRC", "TRCK", "TPOS", "TCON",
        "TCOM", "TPUB", "TEXT", "TENC", "TSSE", "TLEN",
        "TBPM", "TKEY", "TLAN", "TFLT", "TMED", "TSRC",
        "TOAL", "TOFN", "TOLY", "TOPE", "TOWN", "TRSN",
        "TRSO", "TSOA", "TSOP", "TSOT", "TSST", "TMOO",
        "TPRO", "TDEN", "TDOR", "TDRL", "TDTG", "TSIZ"
    };
    uint32 size <min=4, max=128>;
    ID3V2_FRAME_FLAGS flags;
    // encoding: 0=ISO-8859-1, 1=UTF-16 BOM, 2=UTF-16BE, 3=UTF-8
    ubyte encoding <min=0, max=3>;
    if (size > 1) {
        char text_data[size - 1];
    }
};

struct ID3V2_COMM_FRAME {
    char id[4] = { "COMM" };
    uint32 size <min=6, max=256>;
    ID3V2_FRAME_FLAGS flags;
    ubyte encoding <min=0, max=3>;
    char language[3];  // ISO-639-2
    // short description + null + text
    if (size > 4) {
        char comment_data[size - 4];
    }
};

struct ID3V2_APIC_FRAME {
    char id[4] = { "APIC" };
    uint32 size <min=14, max=4096>;
    ID3V2_FRAME_FLAGS flags;
    ubyte encoding <min=0, max=3>;
    // mime type (null-terminated), picture type, description, data
    char mime_type[10] = { "image/jpeg" };
    ubyte null_term1 = { 0 };
    // picture_type: 0-20 per spec
    ubyte picture_type <min=0, max=20>;
    ubyte null_term2 = { 0 };
    // remaining is picture data
    local uint32 pic_data_size = size - 14;
    if (pic_data_size > 0) {
        ubyte picture_data[pic_data_size];
    }
};

struct ID3V2_USLT_FRAME {
    char id[4] = { "USLT" };
    uint32 size <min=5, max=4096>;
    ID3V2_FRAME_FLAGS flags;
    ubyte encoding <min=0, max=3>;
    char language[3];
    if (size > 4) {
        char lyrics_data[size - 4];
    }
};

struct ID3V2_TXXX_FRAME {
    char id[4] = { "TXXX" };
    uint32 size <min=4, max=256>;
    ID3V2_FRAME_FLAGS flags;
    ubyte encoding <min=0, max=3>;
    if (size > 1) {
        char txxx_data[size - 1]; // description + null + value
    }
};

struct ID3V2_WXXX_FRAME {
    char id[4] = { "WXXX" };
    uint32 size <min=4, max=256>;
    ID3V2_FRAME_FLAGS flags;
    ubyte encoding <min=0, max=3>;
    if (size > 1) {
        char wxxx_data[size - 1]; // description + null + URL
    }
};

struct ID3V2_URL_FRAME {
    char id[4] = { "WOAR", "WOAF", "WOAS", "WORS", "WPAY", "WPUB" };
    uint32 size <min=4, max=256>;
    ID3V2_FRAME_FLAGS flags;
    char url[size];
};

struct ID3V2_PCNT_FRAME {
    char id[4] = { "PCNT" };
    uint32 size <min=4, max=8>;
