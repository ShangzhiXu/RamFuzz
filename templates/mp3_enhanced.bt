    char id[4] = { "SYTC" };
    uint32 size <min=2, max=256>;
    ID3V2_FRAME_FLAGS flags;
    ubyte timestamp_format <min=1, max=2>;
    if (size > 1) {
        ubyte tempo_data[size - 1];
    }
};

struct ID3V2_MLLT_FRAME {
    char id[4] = { "MLLT" };
    uint32 size <min=10, max=256>;
    ID3V2_FRAME_FLAGS flags;
    uint16 frames_between_ref;
    // uint24 bytes_between_ref (3 bytes)
    ubyte bbr_hi;
    uint16 bbr_lo;
    // uint24 ms_between_ref (3 bytes)
    ubyte mbr_hi;
    uint16 mbr_lo;
    ubyte bits_for_bytes_dev;
    ubyte bits_for_ms_dev;
    if (size > 10) {
        ubyte deviation_data[size - 10];
    }
};

struct ID3V2_RBUF_FRAME {
    char id[4] = { "RBUF" };
    uint32 size <min=4, max=8>;
    ID3V2_FRAME_FLAGS flags;
    // uint24 buffer size
    ubyte buf_hi;
    uint16 buf_lo;
    ubyte embedded_info_flag <min=0, max=1>;
    if (size > 4) {
        uint32 offset_to_next;
    }
};

struct ID3V2_AENC_FRAME {
    char id[4] = { "AENC" };
    uint32 size <min=6, max=256>;
    ID3V2_FRAME_FLAGS flags;
    ubyte aenc_data[size]; // owner + preview_start + preview_len + enc_info
};

struct ID3V2_ENCR_FRAME {
    char id[4] = { "ENCR" };
    uint32 size <min=3, max=256>;
    ID3V2_FRAME_FLAGS flags;
    ubyte encr_data[size];
};

struct ID3V2_GRID_FRAME {
    char id[4] = { "GRID" };
    uint32 size <min=3, max=256>;
    ID3V2_FRAME_FLAGS flags;
    ubyte grid_data[size];
};

struct ID3V2_LINK_FRAME {
    char id[4] = { "LINK" };
    uint32 size <min=5, max=256>;
