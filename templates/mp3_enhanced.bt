    ID3V2_FRAME_FLAGS flags;
    uint16 reverb_left;
    uint16 reverb_right;
    ubyte reverb_bounces_left;
    ubyte reverb_bounces_right;
    ubyte feedback_ll;
    ubyte feedback_lr;
    ubyte feedback_rr;
    ubyte feedback_rl;
