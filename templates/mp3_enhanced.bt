    if (size > 4) {
        ubyte link_data[size - 4];
    }
};

struct ID3V2_USER_FRAME {
    char id[4] = { "USER" };
    uint32 size <min=5, max=256>;
    ID3V2_FRAME_FLAGS flags;
    ubyte encoding <min=0, max=3>;
    char language[3];
    if (size > 4) {
        char terms_text[size - 4];
    }
};

struct ID3V2_OWNE_FRAME {
    char id[4] = { "OWNE" };
    uint32 size <min=10, max=256>;
    ID3V2_FRAME_FLAGS flags;
    ubyte encoding <min=0, max=3>;
    if (size > 1) {
        ubyte owne_data[size - 1]; // price + null + date + seller
    }
};

struct ID3V2_CHAP_FRAME {
    char id[4] = { "CHAP" };
    uint32 size <min=18, max=512>;
    ID3V2_FRAME_FLAGS flags;
    ubyte chap_data[size]; // element_id + null + times + offsets + sub-frames
};

struct ID3V2_CTOC_FRAME {
    char id[4] = { "CTOC" };
    uint32 size <min=4, max=256>;
    ID3V2_FRAME_FLAGS flags;
    ubyte ctoc_data[size]; // element_id + null + flags + entry_count + entries
};

struct ID3V2_SEEK_FRAME {
    char id[4] = { "SEEK" };
    uint32 size = { 4 };
    ID3V2_FRAME_FLAGS flags;
    uint32 min_offset_to_next;
};

struct ID3V2_SIGN_FRAME {
    char id[4] = { "SIGN" };
    uint32 size <min=2, max=256>;
    ID3V2_FRAME_FLAGS flags;
    ubyte group_symbol;
    if (size > 1) {
        ubyte signature[size - 1];
    }
};

struct ID3V2_ASPI_FRAME {
    char id[4] = { "ASPI" };
    uint32 size <min=11, max=1024>;
    ID3V2_FRAME_FLAGS flags;
    uint32 indexed_data_start;
    uint32 indexed_data_length;
    uint16 num_index_points;
    ubyte bits_per_index <min=8, max=16>;
    // index point data follows, but variable
};

struct ID3V2_RGAD_FRAME {
    char id[4] = { "RGAD" };
    uint32 size = { 8 };
    ID3V2_FRAME_FLAGS flags;
    uint32 peak_signal; // float32 as raw bytes
    uint16 radio_gain;
    uint16 audiophile_gain;
};

struct ID3V2_GENERIC_FRAME {
    char id[4] = {
        "COMR", "POSS"
    };
    uint32 size <min=1, max=256>;
    ID3V2_FRAME_FLAGS flags;
    ubyte frame_data[size];
};

// ---- ID3v2 Tag ----
struct mp3_id3v2_tag {
    Printf("=== ID3v2 Tag ===\n");

    // Header
    char header_id[3] = { "ID3" };
    ubyte version_major = { 3, 4 };
    ubyte version_minor = { 0 };

    // Flags byte
    ubyte header_flags = { 0 };

    // Size (synchsafe)
    local int64 size_pos = FTell();
    uint32 raw_size <min=40, max=2048>;

    // Re-encode as synchsafe
    FSeek(size_pos);
    write_syncsafe_at(raw_size, size_pos);
    local uint32 tag_body_size = raw_size;

    local int64 tag_data_start = FTell();

    // Generate frames
    local int frame_count = 0;
    local string frame_choices[] = {
        "TEXT", "COMM", "APIC", "USLT", "TXXX", "WXXX", "WURL",
        "PCNT", "POPM", "PRIV", "UFID", "GEOB", "MCDI", "ETCO",
        "SYLT", "RVA2", "EQU2", "RVRB", "SYTC", "MLLT", "RBUF",
        "AENC", "ENCR", "GRID", "LINK", "USER", "OWNE", "CHAP",
        "CTOC", "SIGN", "ASPI", "RGAD"
    };

    local char next_frame[4];
    while (frame_count < MAX_ID3V2_FRAMES &&
           (FTell() - tag_data_start) < (tag_body_size - 10) &&
           ReadBytes(next_frame, FTell(), 4, frame_choices, frame_choices))
    {
        switch (next_frame) {
            case "TEXT": ID3V2_TEXT_FRAME text_frame; break;
            case "COMM": ID3V2_COMM_FRAME comm_frame; break;
            case "APIC": ID3V2_APIC_FRAME apic_frame; break;
            case "USLT": ID3V2_USLT_FRAME uslt_frame; break;
            case "TXXX": ID3V2_TXXX_FRAME txxx_frame; break;
            case "WXXX": ID3V2_WXXX_FRAME wxxx_frame; break;
            case "WURL": ID3V2_URL_FRAME url_frame; break;
            case "PCNT": ID3V2_PCNT_FRAME pcnt_frame; break;
            case "POPM": ID3V2_POPM_FRAME popm_frame; break;
            case "PRIV": ID3V2_PRIV_FRAME priv_frame; break;
            case "UFID": ID3V2_UFID_FRAME ufid_frame; break;
            case "GEOB": ID3V2_GEOB_FRAME geob_frame; break;
            case "MCDI": ID3V2_MCDI_FRAME mcdi_frame; break;
            case "ETCO": ID3V2_ETCO_FRAME etco_frame; break;
            case "SYLT": ID3V2_SYLT_FRAME sylt_frame; break;
            case "RVA2": ID3V2_RVA2_FRAME rva2_frame; break;
            case "EQU2": ID3V2_EQU2_FRAME equ2_frame; break;
            case "RVRB": ID3V2_RVRB_FRAME rvrb_frame; break;
            case "SYTC": ID3V2_SYTC_FRAME sytc_frame; break;
            case "MLLT": ID3V2_MLLT_FRAME mllt_frame; break;
            case "RBUF": ID3V2_RBUF_FRAME rbuf_frame; break;
            case "AENC": ID3V2_AENC_FRAME aenc_frame; break;
            case "ENCR": ID3V2_ENCR_FRAME encr_frame; break;
            case "GRID": ID3V2_GRID_FRAME grid_frame; break;
            case "LINK": ID3V2_LINK_FRAME link_frame; break;
            case "USER": ID3V2_USER_FRAME user_frame; break;
            case "OWNE": ID3V2_OWNE_FRAME owne_frame; break;
            case "CHAP": ID3V2_CHAP_FRAME chap_frame; break;
            case "CTOC": ID3V2_CTOC_FRAME ctoc_frame; break;
            case "SIGN": ID3V2_SIGN_FRAME sign_frame; break;
            case "ASPI": ID3V2_ASPI_FRAME aspi_frame; break;
            case "RGAD": ID3V2_RGAD_FRAME rgad_frame; break;
            default:     ID3V2_GENERIC_FRAME gen_frame; break;
        }
        frame_count++;
        frame_choices -= next_frame;
    }

    // Padding to fill remaining tag space
    local int64 bytes_written = FTell() - tag_data_start;
    local int64 padding_needed = tag_body_size - bytes_written;
    if (padding_needed > 0 && padding_needed < 65536) {
        ubyte padding[padding_needed];
    }
};

// ============================================================
// MPEG Audio Frame Header + Side Info + Main Data
// ============================================================

struct mp3_mpeg_header {
    // Byte 1: always 0xFF (sync)
    ubyte sync_byte1 = { 0xFF };

    // Byte 2: 111VVLLP - remaining sync(3) + version(2) + layer(2) + protection(1)
    // We fix sync bits to 111 = 0xE0, then add version/layer/protection
    // Valid: MPEG1 Layer3 unprotected = 0xFB, protected = 0xFA
    //        MPEG1 Layer3 = 11 01 1 = 0xFB/0xFA
    //        MPEG2 Layer3 = 10 01 1 = 0xF3/0xF2
    ubyte sync_byte2 = { 0xFB, 0xFA, 0xF3, 0xF2, 0xFF, 0xFE, 0xFD, 0xFC };

    // Extract fields from byte2
    local ubyte mpeg_version = (sync_byte2 >> 3) & 3;  // 0=2.5, 2=MPEG2, 3=MPEG1
    local ubyte layer = (sync_byte2 >> 1) & 3;          // 1=L3, 2=L2, 3=L1
    local ubyte protection = sync_byte2 & 1;             // 0=CRC, 1=none

    // Byte 3: EEEEFFGH = bitrate(4) + samplerate(2) + padding(1) + private(1)
    // Construct valid byte: bitrate_index in [1..14], sr_index in [0..2]
    // For MPEG1 Layer3 128kbps 44100Hz no-padding: bitrate=9, sr=0 -> 0x90
    ubyte header_byte3 <min=0x10, max=0xFD>;

    local ubyte bitrate_index = (header_byte3 >> 4) & 0xF;
    local ubyte sample_rate_index = (header_byte3 >> 2) & 3;
    local ubyte padding_bit = (header_byte3 >> 1) & 1;
    local ubyte private_bit = header_byte3 & 1;

    // Byte 4: IIJJKLMM = channel(2) + mode_ext(2) + copyright(1) + original(1) + emphasis(2)
    ubyte header_byte4;

    local ubyte channel_mode = (header_byte4 >> 6) & 3;
    local ubyte mode_extension = (header_byte4 >> 4) & 3;
    local ubyte copyright_bit = (header_byte4 >> 3) & 1;
    local ubyte original_bit = (header_byte4 >> 2) & 1;
    local ubyte emphasis = header_byte4 & 3;

    // CRC if protected
    if (protection == 0) {
        uint16 crc16;
    }

    // Calculate frame data size
    local uint32 ver_idx = (mpeg_version == 3) ? 1 : 0;
    local uint32 lay_idx;
    if (layer == 3) lay_idx = 0;
    else if (layer == 2) lay_idx = 1;
    else lay_idx = 2;

    local uint32 bi = bitrate_index;
    if (bi < 1) bi = 1;
    if (bi > 14) bi = 14;
    local uint32 si = sample_rate_index;
    if (si > 2) si = 0;

    local uint32 br = bitrate_table[(ver_idx * 3 + lay_idx) * 16 + bi];
    local uint32 sr = samplerate_table[mpeg_version * 4 + si];
    local uint32 spf = samples_per_frame[mpeg_version * 4 + layer];

    local uint32 frame_data_size = 0;
    if (sr > 0 && br > 0) {
        if (layer == 3) {
            frame_data_size = (12 * br * 1000 / sr + padding_bit) * 4;
        } else {
            frame_data_size = spf / 8 * br * 1000 / sr + padding_bit;
        }
        local uint32 hdr_size = 4 + (protection == 0 ? 2 : 0);
        if (frame_data_size > hdr_size)
            frame_data_size -= hdr_size;
        else
            frame_data_size = 32;
    } else {
        frame_data_size = 128;
    }

    // Cap frame data size to something reasonable
    if (frame_data_size > 4096)
        frame_data_size = 1024;
};

struct mp3_xing_header {
    // Xing/Info header embedded in first MPEG frame's data
    char xing_id[4] = { "Xing", "Info" };
    uint32 xing_flags <min=0, max=15>;

    if (xing_flags & 1) {
        uint32 num_frames;
    }
    if (xing_flags & 2) {
        uint32 num_bytes;
    }
    if (xing_flags & 4) {
        ubyte toc[100]; // seek table
    }
    if (xing_flags & 8) {
        uint32 quality <min=0, max=100>;
    }
};

struct mp3_lame_header {
    char encoder_version[9]; // e.g. "LAME3.100"

    // info tag revision (4 bits) + vbr method (4 bits)
    ubyte info_vbr;

    ubyte lowpass_freq; // in units of 100Hz

    // Replay gain: peak + radio + audiophile
    uint32 replay_gain_peak;
    uint16 replay_gain_radio;
    uint16 replay_gain_audiophile;

    // encoding flags + ATH type
    ubyte encoding_flags_ath;

    ubyte min_bitrate; // or target ABR, or CBR bitrate

    // encoder delay: 12 bits start + 12 bits end = 3 bytes
    ubyte delay_bytes[3];

    // misc: source freq (2), noise shaping (2), stereo mode (3), unwise (1)
    ubyte misc_byte;

    ubyte mp3_gain; // signed, each step = 1.5 dB

    // preset + surround info
    uint16 preset;

    uint32 music_length;

    uint16 music_crc;
    uint16 info_tag_crc;
};

struct mp3_vbri_header {
    char vbri_id[4] = { "VBRI" };
    uint16 version = { 1 };
    uint16 delay;
    uint16 quality <min=0, max=100>;
    uint32 num_bytes;
    uint32 num_frames;
    uint16 num_toc_entries <min=1, max=512>;
    uint16 toc_scale_factor <min=1, max=100>;
    uint16 toc_entry_size <min=1, max=4>;
    uint16 toc_entry_frames <min=1, max=256>;
    // TOC entries follow
    local uint32 toc_data_size = num_toc_entries * toc_entry_size;
    if (toc_data_size > 0 && toc_data_size < 4096) {
        ubyte toc_data[toc_data_size];
    }
};

struct mp3_mpeg_frame {
    Printf("=== MPEG Frame ===\n");
    mp3_mpeg_header hdr;

    // For first frame, optionally include Xing/LAME or VBRI header
    // Side info is embedded in frame data
    // side_info: main_data_begin, private_bits, scfsi, granule info
    // (part2_3_length, big_values, global_gain, scalefac_compress,
    //  windows_switching_flag, block_type, mixed_block_flag,
    //  table_select, subblock_gain, region0/1_count,
    //  preflag, scalefac_scale, count1table_select)
    // Then main_data: scalefactors + huffman_data

    if (hdr.frame_data_size > 0) {
        ubyte frame_data[hdr.frame_data_size];
    }
};

// ============================================================
// ID3v1 / ID3v1.1 Tag (128 bytes at end)
// ============================================================

struct mp3_id3v1_tag {
    Printf("=== ID3v1 Tag ===\n");
    char tag_id[3] = { "TAG" };
    char title[30];
    char artist[30];
    char album[30];
    char year[4];
    // ID3v1.1: comment[28] + zero_byte + track
    // ID3v1.0: comment[30]
    char comment[28];
    ubyte zero_byte = { 0 };
    ubyte track <min=1, max=255>;
    // genre (0-79 standard, 80-191 extended, 255=unspecified)
    ubyte genre <min=0, max=191>;
};

// ============================================================
// ID3v1 Enhanced Tag (TAG+ before TAG, 227 bytes)
// ============================================================

struct mp3_id3v1_enhanced {
    Printf("=== ID3v1 Enhanced Tag ===\n");
    char tag_plus_id[4] = { "TAG+" };
    char ext_title[60];
    char ext_artist[60];
    char ext_album[60];
    ubyte speed <min=0, max=4>; // 0=unset,1=slow,2=medium,3=fast,4=hardcore
    char genre_str[30];
    char start_time[6]; // mmm:ss
    char end_time[6];   // mmm:ss
};

// ============================================================
// APE Tag (v1/v2)
// ============================================================

struct ape_item {
    uint32 value_size <min=1, max=4096>;
    uint32 item_flags;
    // key (null-terminated)
    char key[8] = {
        "Title\0\0\0", "Artist\0\0", "Album\0\0\0", "Year\0\0\0\0", "Genre\0\0\0",
        "Track\0\0\0", "Disc\0\0\0\0", "BPM\0\0\0\0\0", "Lyrics\0\0", "Encoder\0"
    };
    ubyte key_null = { 0 };
    // value
    if (value_size > 0 && value_size < 4096) {
        ubyte value[value_size];
    }
};

struct mp3_ape_tag {
    Printf("=== APE Tag ===\n");
    // Header (APEv2)
    char preamble[8] = { "APETAGEX" };
    uint32 version = { 2000 };
    uint32 tag_size <min=32, max=65536>; // includes footer, excludes header
    uint32 item_count <min=1, max=16>;
    uint32 ape_flags;
    ubyte reserved[8];

    // Items
    local uint32 i;
    local uint32 real_items = (item_count < 8) ? item_count : 8;
    for (i = 0; i < real_items; i++) {
        ape_item item;
    }

    // Footer
    char footer_preamble[8] = { "APETAGEX" };
    uint32 footer_version = { 2000 };
    uint32 footer_tag_size;
    uint32 footer_item_count;
    uint32 footer_flags;
    ubyte footer_reserved[8];
};

// ============================================================
// Lyrics3v2 Tag
// ============================================================

struct lyrics3v2_field {
    char field_id[3] = { "LYR", "INF", "AUT", "EAL", "EAR", "ETT", "IMG", "IND" };
    // 5-digit numeric size
    char field_size[5];
    // parse numeric size
    local uint32 fsize = Atoi(field_size);
    if (fsize > 0 && fsize < 4096) {
        char content[fsize];
    }
};

struct mp3_lyrics3v2_tag {
    Printf("=== Lyrics3v2 Tag ===\n");
    char header[11] = { "LYRICSBEGIN" };

    // Fields
    local int fcount = 0;
    while (fcount < 5) {
        lyrics3v2_field field;
        fcount++;
    }

    // Footer: 6-digit size + "LYRICS200"
    char footer_size[6];
    char footer_id[9] = { "LYRICS200" };
};

// ============================================================
// Top-Level MP3 File Structure
// ============================================================

typedef struct {
    // 1. ID3v2 tag at the beginning
    mp3_id3v2_tag id3v2;

    // 2. One MPEG audio frame (contains side info + main data)
    mp3_mpeg_frame frame;

    // 3. ID3v1 tag at the end (128 bytes)
    mp3_id3v1_tag id3v1;

} mp3_file;

mp3_file file;
